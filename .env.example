# ── LinkNav MCP configuration ────────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit .env.

# REQUIRED: your LinkedIn session cookie (the auth token).
# How to get it: log into linkedin.com in your browser → DevTools (F12)
#   → Application/Storage → Cookies → https://www.linkedin.com
#   → copy the VALUE of the `li_at` cookie (a long string).
LINKNAV_LI_AT=

# REQUIRED: the JSESSIONID cookie value (used as the CSRF token).
# Same place as above. Copy the VALUE of `JSESSIONID`. It looks like: ajax:1234567890123456789
# Paste it WITHOUT the surrounding quotes.
LINKNAV_JSESSIONID=

# REQUIRED for people-search: your FULL linkedin.com cookie string.
# The SSR search endpoint (and, in practice, the voyager API) bounce a li_at-only
# request through the login wall. Copy the entire Cookie header from a logged-in
# request: DevTools → Network → any linkedin.com request → Request Headers → cookie.
# Paste the whole "name=value; name2=value2; ..." string here.
# NOTE: LinkedIn rotates session cookies (lidc, JSESSIONID, __cf_bm) every few
# minutes. When search starts returning a 302 redirect loop, re-copy this value.
LINKNAV_COOKIE=

# Optional: override the realistic browser User-Agent sent with requests.
# Default mirrors a current desktop Chrome. Match your real browser if you want.
# LINKNAV_USER_AGENT=

# Optional: pin the people-search GraphQL queryId. Only used by the legacy graphql
# fallback path (primary search is SSR and needs no queryId). LinkedIn rotates this;
# linknav_doctor / linknav_set_search_query_id manage it for you.
# LINKNAV_SEARCH_QUERY_ID=

# Optional: where the SQLite DB lives. Default: <project>/data/linknav.db
# LINKNAV_DB_PATH=

# Activity recency (the "active in last 24h" filter) is scraped from your real
# logged-in browser over CDP, because the feed hydrates client-side via a Service
# Worker and isn't in the headless HTML. Needs Edge/Chrome started with remote
# debugging (chrome://inspect/#remote-debugging). Default true; auto-skips with a
# graceful fallback (keep all matches) when no debuggable browser is reachable.
LINKNAV_USE_CDP_ACTIVITY=true

# ── Safety caps (ban mitigation — keep these conservative) ───────────────────
# Per-rolling-24h hard ceilings. Actions beyond the cap are refused, not queued.
LINKNAV_CAP_PROFILE_VIEWS=80
LINKNAV_CAP_CONNECTS=20
LINKNAV_CAP_MESSAGES=25
LINKNAV_CAP_SEARCHES=40

# Human-pacing jitter between any two write/read actions (milliseconds).
LINKNAV_MIN_DELAY_MS=3500
LINKNAV_MAX_DELAY_MS=12000
